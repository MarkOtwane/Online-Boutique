generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id              Int                     @id @default(autoincrement())
  name            String
  price           Float
  imageUrl        String?
  createdAt       DateTime                @default(now())
  commentCount    Int                     @default(0)
  repostCount     Int                     @default(0)
  reactionCount   Int                     @default(0)
  categoryId      Int
  comments        Comment[]
  orderItems      OrderItem[]
  category        Category                @relation(fields: [categoryId], references: [id])
  reposts         Repost[]
  reactions       Reaction[]
  communityPosts  CommunityPost[]
  reviews         Review[]
  userBehaviors   UserBehavior[]
  recommendations ProductRecommendation[]
}

model User {
  id                 Int                     @id @default(autoincrement())
  email              String                  @unique
  password           String
  role               String                  @default("customer")
  createdAt          DateTime                @default(now())
  isOnline           Boolean                 @default(false)
  lastSeen           DateTime                @default(now())
  chatPublicKey      String?
  conversationsAsP1  ChatConversation[]      @relation("ConversationParticipant1")
  conversationsAsP2  ChatConversation[]      @relation("ConversationParticipant2")
  sentMessages       ChatMessage[]           @relation("MessageSender")
  comments           Comment[]
  orders             Order[]
  reposts            Repost[]
  reactions          Reaction[]
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]
  communityReactions CommunityReaction[]
  communityReposts   CommunityRepost[]
  emailLogs          EmailLog[]
  reviews            Review[]
  userBehaviors      UserBehavior[]
  reviewHelpfulness  UserReviewHelpfulness[]
  recommendations    ProductRecommendation[]
}

model Order {
  id                Int            @id @default(autoincrement())
  userId            Int
  total             Float
  paymentStatus     PaymentStatus  @default(PENDING)
  paymentMethod     PaymentMethod?
  phoneNumber       String?
  transactionId     String?
  paymentAmount     Float?
  paymentDate       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  checkoutRequestId String?
  isStatusFinal     Boolean        @default(false) // Track if order status has been finalized
  user              User           @relation(fields: [userId], references: [id])
  orderItems        OrderItem[]
  tracking          OrderTracking?
  emailLogs         EmailLog[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Comment {
  id                 Int       @id @default(autoincrement())
  productId          Int
  userId             Int
  content            String
  parentId           Int?
  isAdminResponse    Boolean   @default(false)
  isOfficialResponse Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  parent             Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies            Comment[] @relation("CommentReplies")
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([isAdminResponse])
  @@index([isOfficialResponse])
}

model Repost {
  id        Int      @id @default(autoincrement())
  productId Int
  userId    Int
  content   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

model ChatConversation {
  id                    String        @id @default(uuid()) @db.Uuid
  participant1Id        Int
  participant2Id        Int
  participant1KeyBundle String
  participant2KeyBundle String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  participant1          User          @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2          User          @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages              ChatMessage[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
}

model ChatMessage {
  id               String           @id @default(uuid()) @db.Uuid
  conversationId   String           @db.Uuid
  senderId         Int
  encryptedContent String
  iv               String
  algorithm        String           @default("AES-GCM")
  clientMessageId  String?
  isRead           Boolean          @default(false)
  readAt           DateTime?
  createdAt        DateTime         @default(now())
  conversation     ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender           User             @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentMethod {
  MPESA
  CARD
  CASH
}

enum PostType {
  GENERAL
  PRODUCT_REVIEW
  LIFESTYLE
  TRENDS
  ADMIN_ANNOUNCEMENT
}

model Reaction {
  id           Int      @id @default(autoincrement())
  productId    Int
  userId       Int
  reactionKind String   @default("like")
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

model CommunityPost {
  id            Int                 @id @default(autoincrement())
  userId        Int
  productId     Int?
  content       String
  imageUrl      String?
  caption       String
  postType      PostType            @default(GENERAL)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  commentCount  Int                 @default(0)
  reactionCount Int                 @default(0)
  shareCount    Int                 @default(0)
  repostCount   Int                 @default(0)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product?            @relation(fields: [productId], references: [id], onDelete: Cascade)
  comments      CommunityComment[]
  reactions     CommunityReaction[]
  reposts       CommunityRepost[]

  @@index([userId])
  @@index([productId])
  @@index([postType])
  @@index([createdAt])
}

model CommunityComment {
  id              Int                @id @default(autoincrement())
  communityPostId Int
  userId          Int
  content         String
  parentId        Int?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  post            CommunityPost      @relation(fields: [communityPostId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent          CommunityComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies         CommunityComment[] @relation("CommentReplies")

  @@index([communityPostId])
  @@index([userId])
  @@index([parentId])
}

model CommunityReaction {
  id              Int           @id @default(autoincrement())
  communityPostId Int
  userId          Int
  type            String        @default("like")
  createdAt       DateTime      @default(now())
  post            CommunityPost @relation(fields: [communityPostId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityPostId, userId])
  @@index([communityPostId])
  @@index([userId])
}

model CommunityRepost {
  id              Int           @id @default(autoincrement())
  communityPostId Int
  userId          Int
  content         String?
  createdAt       DateTime      @default(now())
  post            CommunityPost @relation(fields: [communityPostId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityPostId, userId])
  @@index([communityPostId])
  @@index([userId])
}

model OrderTracking {
  id            Int                  @id @default(autoincrement())
  orderId       Int                  @unique
  trackingId    String               @unique // UUID-based
  currentStatus TrackingStatus
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  order         Order                @relation(fields: [orderId], references: [id])
  checkpoints   TrackingCheckpoint[]

  @@index([trackingId])
  @@index([currentStatus])
}

model TrackingCheckpoint {
  id         Int            @id @default(autoincrement())
  trackingId Int
  status     TrackingStatus
  location   String
  notes      String?
  timestamp  DateTime       @default(now())
  tracking   OrderTracking  @relation(fields: [trackingId], references: [id], onDelete: Cascade)

  @@index([trackingId])
  @@index([status])
}

model EmailLog {
  id        Int         @id @default(autoincrement())
  to        String
  subject   String
  template  String
  status    EmailStatus
  provider  String
  error     String?
  sentAt    DateTime?
  createdAt DateTime    @default(now())
  orderId   Int?
  userId    Int?
  order     Order?      @relation(fields: [orderId], references: [id])
  user      User?       @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

enum TrackingStatus {
  ORDER_PLACED
  PROCESSING
  DISPATCHED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
  BOUNCED
}

model Review {
  id               Int      @id @default(autoincrement())
  productId        Int
  userId           Int
  title            String?
  content          String
  rating           Int
  verifiedPurchase Boolean  @default(false)
  helpfulCount     Int      @default(0)
  notHelpfulCount  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isApproved       Boolean  @default(false)
  reviewImages     String[]

  product     Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  helpfulness UserReviewHelpfulness[]

  @@index([productId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
  @@index([isApproved])
}

model UserReviewHelpfulness {
  id        Int      @id @default(autoincrement())
  reviewId  Int
  userId    Int
  isHelpful Boolean
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
}

model UserBehavior {
  id         Int      @id @default(autoincrement())
  userId     Int
  productId  Int?
  actionType String // 'view', 'cart_add', 'purchase', 'review', 'search'
  metadata   Json?
  timestamp  DateTime @default(now())
  sessionId  String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([productId])
  @@index([actionType])
  @@index([timestamp])
  @@index([sessionId])
}

model ProductRecommendation {
  id                 Int      @id @default(autoincrement())
  userId             Int
  productId          Int
  recommendationType String // 'collaborative', 'content_based', 'trending', 'personalized'
  score              Float // AI confidence score
  reason             String? // Explanation for the recommendation
  createdAt          DateTime @default(now())
  isViewed           Boolean  @default(false)
  isClicked          Boolean  @default(false)
  isPurchased        Boolean  @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, recommendationType])
  @@index([userId])
  @@index([productId])
  @@index([recommendationType])
  @@index([score])
  @@index([createdAt])
}
